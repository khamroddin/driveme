<div class="d-flex justify-content-between align-items-center mb-4">

  <div>
    <h2>Booking Details</h2>
    <p class="text-muted mb-0">
      Booking No: <strong><%= @booking.booking_number %></strong>
    </p>
  </div>

  <%= link_to "Back to Bookings",
        admin_bookings_path,
        class: "btn btn-outline-secondary" %>

</div>

<div class="row">

  <!-- Booking Information -->
  <div class="col-lg-8">

    <div class="card shadow-sm border-0 mb-4">

      <div class="card-header bg-white">
        <strong>Booking Information</strong>
      </div>

      <div class="card-body">

        <div class="row">

          <div class="col-md-6 mb-3">
            <strong>Customer</strong>
            <p><%= @booking.customer.full_name %></p>
          </div>

          <div class="col-md-6 mb-3">
            <strong>Email</strong>
            <p><%= @booking.customer.email %></p>
          </div>

          <div class="col-md-6 mb-3">
            <strong>Mobile</strong>
            <p><%= @booking.customer.mobile %></p>
          </div>

          <div class="col-md-6 mb-3">
            <strong>Status</strong>

            <% badge_class =
              case @booking.status
              when "pending" then "bg-warning"
              when "confirmed" then "bg-primary"
              when "ongoing" then "bg-info"
              when "completed" then "bg-success"
              when "cancelled" then "bg-danger"
              end %>

            <p>
              <span class="badge <%= badge_class %>">
                <%= @booking.status.titleize %>
              </span>
            </p>

          </div>

        </div>

      </div>

    </div>

    <!-- Vehicle -->

    <div class="card shadow-sm border-0 mb-4">

      <div class="card-header bg-white">
        <strong>Vehicle</strong>
      </div>

      <div class="card-body">

        <div class="row">

          <div class="col-md-6">
            <strong>Brand</strong>
            <p><%= @booking.vehicle.vehicle_brand.name %></p>
          </div>

          <div class="col-md-6">
            <strong>Model</strong>
            <p><%= @booking.vehicle.model %></p>
          </div>

          <div class="col-md-6">
            <strong>Pickup Location</strong>
            <p><%= @booking.pickup_location.name %></p>
          </div>

          <div class="col-md-6">
            <strong>Drop Location</strong>
            <p><%= @booking.drop_location.name %></p>
          </div>

          <div class="col-md-6">
            <strong>Pickup</strong>
            <p>
              <%= @booking.pickup_date.strftime("%d %b %Y") %>
              <br>
              <%= @booking.pickup_time.strftime("%I:%M %p") %>
            </p>
          </div>

          <div class="col-md-6">
            <strong>Return</strong>
            <p>
              <%= @booking.return_date.strftime("%d %b %Y") %>
              <br>
              <%= @booking.return_time.strftime("%I:%M %p") %>
            </p>
          </div>

        </div>

      </div>

    </div>

  </div>

  <!-- Summary -->

  <div class="col-lg-4">

    <div class="card shadow-sm border-0">

      <div class="card-header bg-white">
        <strong>Booking Summary</strong>
      </div>

      <div class="card-body">

        <table class="table table-borderless mb-4">

          <tr>
            <th>Days</th>
            <td class="text-end"><%= @booking.days %></td>
          </tr>

          <tr>
            <th>Daily Rate</th>
            <td class="text-end">
              ₹<%= number_with_precision(@booking.rate, precision: 2) %>
            </td>
          </tr>

          <tr>
            <th>Subtotal</th>
            <td class="text-end">
              ₹<%= number_with_precision(@booking.subtotal, precision: 2) %>
            </td>
          </tr>

          <tr>
            <th>Deposit</th>
            <td class="text-end">
              ₹<%= number_with_precision(@booking.security_deposit, precision: 2) %>
            </td>
          </tr>

          <tr>
            <th>Discount</th>
            <td class="text-end">
              ₹<%= number_with_precision(@booking.discount, precision: 2) %>
            </td>
          </tr>

          <tr>
            <th>Tax</th>
            <td class="text-end">
              ₹<%= number_with_precision(@booking.tax, precision: 2) %>
            </td>
          </tr>

          <tr class="table-light">
            <th>Total</th>
            <th class="text-end">
              ₹<%= number_with_precision(@booking.total_amount, precision: 2) %>
            </th>
          </tr>

        </table>

        <% if @booking.pending? %>

          <div class="d-grid gap-2">

            <%= button_to "Approve Booking",
                  approve_admin_booking_path(@booking),
                  method: :patch,
                  class: "btn btn-success" %>

            <%= button_to "Reject Booking",
                  reject_admin_booking_path(@booking),
                  method: :patch,
                  class: "btn btn-danger" %>

          </div>

        <% elsif @booking.confirmed? %>

          <%= button_to "Start Rental",
                start_rental_admin_booking_path(@booking),
                method: :patch,
                class: "btn btn-primary w-100" %>

        <% elsif @booking.ongoing? %>

          <%= button_to "Complete Rental",
                complete_rental_admin_booking_path(@booking),
                method: :patch,
                class: "btn btn-success w-100" %>

        <% else %>

          <div class="alert alert-secondary mb-0 text-center">
            No actions available.
          </div>

        <% end %>

      </div>

    </div>

  </div>

</div>
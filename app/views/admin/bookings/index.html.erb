<div class="d-flex justify-content-between align-items-center mb-4">

  <div>
    <h2>Bookings</h2>
    <p class="text-muted mb-0">
      Manage customer bookings.
    </p>
  </div>

</div>

<div class="card shadow-sm border-0">

  <div class="table-responsive">

    <table class="table table-hover align-middle mb-0">

      <thead class="table-light">

        <tr>
          <th>Booking No</th>
          <th>Customer</th>
          <th>Vehicle</th>
          <th>Pickup</th>
          <th>Return</th>
          <th>Status</th>
          <th>Total</th>
          <th width="120"></th>
        </tr>

      </thead>

      <tbody>

        <% @bookings.each do |booking| %>

          <tr>

            <td>
              <strong><%= booking.booking_number %></strong>
            </td>

            <td>
              <%= booking.customer.full_name %>
            </td>

            <td>
              <%= booking.vehicle.vehicle_brand.name %>
              <br>
              <small class="text-muted">
                <%= booking.vehicle.model %>
              </small>
            </td>

            <td>
              <%= booking.pickup_date.strftime("%d %b %Y") %><br>
              <small class="text-muted">
                <%= booking.pickup_time.strftime("%I:%M %p") %>
              </small>
            </td>

            <td>
              <%= booking.return_date.strftime("%d %b %Y") %><br>
              <small class="text-muted">
                <%= booking.return_time.strftime("%I:%M %p") %>
              </small>
            </td>

            <td>

              <% badge_class =
                case booking.status
                when "pending"
                  "bg-warning"
                when "confirmed"
                  "bg-primary"
                when "ongoing"
                  "bg-info"
                when "completed"
                  "bg-success"
                when "cancelled"
                  "bg-danger"
                end %>

              <span class="badge <%= badge_class %>">
                <%= booking.status.titleize %>
              </span>

            </td>

            <td>
              ₹<%= number_with_precision(booking.total_amount, precision: 2) %>
            </td>

            <td>

              <%= link_to "View",
                    admin_booking_path(booking),
                    class: "btn btn-sm btn-outline-primary" %>

            </td>

          </tr>

        <% end %>

      </tbody>

    </table>

  </div>

</div>
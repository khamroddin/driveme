<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>Customers</h2>

  <%= link_to "New Customer",
      new_admin_customer_path,
      class: "btn btn-primary" %>
</div>

<div class="card shadow-sm">
  <div class="card-body">

    <table class="table table-hover">

      <thead>
        <tr>
          <th>Name</th>
          <th>Mobile</th>
          <th>License</th>
          <th>City</th>
          <th>Status</th>
          <th width="140">Actions</th>
        </tr>
      </thead>

      <tbody>

        <% @customers.each do |customer| %>

          <tr>

            <td>
              <strong><%= customer.full_name %></strong><br>
              <small class="text-muted"><%= customer.email %></small>
            </td>

            <td><%= customer.mobile %></td>

            <td><%= customer.driving_license_no %></td>

            <td><%= customer.city %></td>

            <td>
              <% if customer.status? %>
                <span class="badge bg-success">Active</span>
              <% else %>
                <span class="badge bg-secondary">Inactive</span>
              <% end %>
            </td>

            <td>

              <%= link_to edit_admin_customer_path(customer),
                    class: "btn btn-warning btn-sm" do %>
                <i class="bi bi-pencil"></i>
              <% end %>

              <%= link_to admin_customer_path(customer),
                    data: {
                      turbo_method: :delete,
                      turbo_confirm: "Delete customer?"
                    },
                    class: "btn btn-danger btn-sm" do %>
                <i class="bi bi-trash"></i>
              <% end %>

            </td>

          </tr>

        <% end %>

      </tbody>

    </table>

  </div>
</div>
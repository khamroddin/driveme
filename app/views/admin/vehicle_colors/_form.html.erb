<%= form_with model: [:admin, @vehicle_color], local: true do |f| %>

  <% if @vehicle_color.errors.any? %>

    <div class="alert alert-danger">

      <ul class="mb-0">

        <% @vehicle_color.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>

      </ul>

    </div>

  <% end %>

  <div class="mb-3">

    <%= f.label :name, class: "form-label" %>

    <%= f.text_field :name, class: "form-control" %>

  </div>

 

 
  <div class="form-check mb-4">

    <%= f.check_box :active,
          class: "form-check-input" %>

    <%= f.label :active,
          class: "form-check-label" %>

  </div>

  <%= f.submit class: "btn btn-primary" %>

  <%= link_to "Cancel",
      admin_vehicle_colors_path,
      class: "btn btn-secondary" %>

<% end %>
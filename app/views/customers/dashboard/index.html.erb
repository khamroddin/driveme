<div class="mb-4">
  <h3 class="fw-bold">
    Welcome back, <%= current_customer.first_name %> 👋
  </h3>

  <p class="text-muted mb-0">
    Manage your bookings and discover your next ride.
  </p>
</div>

<div class="row g-4 mb-4">

  <!-- Total Bookings -->
  <div class="col-lg-3 col-md-6">
    <%= link_to customers_bookings_path,
          class: "text-decoration-none text-dark" do %>

      <div class="card dashboard-card border-0 shadow-sm text-center h-100">
        <div class="card-body">

          <i class="bi bi-calendar-check fs-1 text-primary mb-3"></i>

          <h3 class="fw-bold"><%= @total_bookings %></h3>

          <p class="text-muted mb-2">
            Total Bookings
          </p>

          <small class="text-primary">
            View →
          </small>

        </div>
      </div>

    <% end %>
  </div>

  <!-- Active Rentals -->
  <div class="col-lg-3 col-md-6">
    <%= link_to customers_bookings_path,
          class: "text-decoration-none text-dark" do %>

      <div class="card dashboard-card border-0 shadow-sm text-center h-100">
        <div class="card-body">

          <i class="bi bi-car-front-fill fs-1 text-success mb-3"></i>

          <h3 class="fw-bold"><%= @active_bookings %></h3>

          <p class="text-muted mb-2">
            Active Rentals
          </p>

          <small class="text-success">
            View →
          </small>

        </div>
      </div>

    <% end %>
  </div>

  <!-- Completed Trips -->
  <div class="col-lg-3 col-md-6">
    <%= link_to customers_bookings_path,
          class: "text-decoration-none text-dark" do %>

      <div class="card dashboard-card border-0 shadow-sm text-center h-100">
        <div class="card-body">

          <i class="bi bi-check-circle-fill fs-1 text-info mb-3"></i>

          <h3 class="fw-bold"><%= @completed_bookings %></h3>

          <p class="text-muted mb-2">
            Completed Trips
          </p>

          <small class="text-info">
            View →
          </small>

        </div>
      </div>

    <% end %>
  </div>

  <!-- Wishlist -->
  <div class="col-lg-3 col-md-6">
    <%= link_to customers_wishlist_index_path,
          class: "text-decoration-none text-dark" do %>

      <div class="card dashboard-card border-0 shadow-sm text-center h-100">
        <div class="card-body">

          <i class="bi bi-heart-fill fs-1 text-danger mb-3"></i>

          <h3 class="fw-bold"><%= @wishlist_count %></h3>

          <p class="text-muted mb-2">
            Wishlist
          </p>

          <small class="text-danger">
            View →
          </small>

        </div>
      </div>

    <% end %>
  </div>

</div>